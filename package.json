{
  "name": "ocrwebapp",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "start": "npm --workspace apps/web run start",
    "lint": "npm --workspace apps/web run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema packages/db/prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.21.0",
    "eslint-config-next": "15.2.0",
    "prisma": "^6.4.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
