# PostgreSQL (Supabase)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ocrwebapp?schema=public"

# App (NextAuth v5)
AUTH_URL="http://localhost:3000"
AUTH_SECRET="replace-with-secure-random-string"
# 互換用: 既存環境で NEXTAUTH_SECRET を使っている場合も可
# NEXTAUTH_SECRET="replace-with-secure-random-string"

# Google OAuth (NextAuth v5)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# OCR / LLM
GOOGLE_CLOUD_PROJECT=""
GOOGLE_APPLICATION_CREDENTIALS=""
OPENAI_API_KEY=""

# Storage
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_ENDPOINT=""

# Cloud Tasks / Worker dispatch (Vercel 本番で必須)
# GCP_SERVICE_ACCOUNT_KEY: Cloud Tasks API 呼び出し用 SA キー JSON（1行文字列として貼り付け）
CLOUD_TASKS_PROJECT=""
CLOUD_TASKS_QUEUE=""
CLOUD_TASKS_LOCATION="asia-northeast1"
WORKER_URL=""
WORKER_SERVICE_ACCOUNT=""
GCP_SERVICE_ACCOUNT_KEY=""

# Supabase PgBouncer/Pooler URL (when enabled in production)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
